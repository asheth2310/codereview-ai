# ── Claude API ──────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_claude_api_key_here

# ── Optional: GitHub Token ───────────────────────────────
# Without this, GitHub limits you to 60 requests/hour
# Get from: https://github.com/settings/tokens → Generate new token (no scopes needed for public repos)
GITHUB_TOKEN=your_github_token_here

# ── Server ───────────────────────────────────────────────
PORT=3001
